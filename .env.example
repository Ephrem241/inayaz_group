# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Sanity (Phase 5, Step 22) ---
# Project ID and dataset are public identifiers, safe to expose to the client
# (NEXT_PUBLIC_* vars are inlined into the browser bundle).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Sanity API version, as a date string (e.g. 2026-01-01). Pin this and bump
# deliberately — see https://www.sanity.io/docs/api-versioning
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-01

# Server-only tokens — NEVER prefix these with NEXT_PUBLIC_, never expose to
# the client. Generate both under sanity.io/manage -> API -> Tokens.
# Read token: "Viewer" role, used to read draft content server-side.
SANITY_API_READ_TOKEN=
# Write token: "Editor" role, used only by the contact form's server action
# to create contactSubmission documents (Phase 5/8). Never used client-side.
SANITY_API_WRITE_TOKEN=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.inayazgroup.com

# --- Email (Phase 8, Resend — not yet integrated) ---
RESEND_API_KEY=
CONTACT_EMAIL=info@inayazgroup.com
ADMIN_EMAIL=
